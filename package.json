{
  "name": "supercollider-notebook",
  "displayName": "SuperCollider Notebook",
  "description": "Minimal VS Code notebook prototype for SuperCollider (execute cells via sclang).",
  "version": "0.0.1",
  "publisher": "gtwiggs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gtwiggs/supercollider-notebook.git"
  },
  "engines": {
    "vscode": "^1.75.0",
    "node": ">= 18"
  },
  "source": "./src/extension.js",
  "main": "./dist/extension.js",
  "scripts": {
    "watch": "parcel watch",
    "build": "parcel build",
    "package": "npm run build && npx @vscode/vsce package",
    "test": "node ./test/test-getScopeRange.js && node ./test/test-serializeNotebook.js"
  },
  "activationEvents": [
    "onNotebook:supercollider-notebook"
  ],
  "categories": [
    "Other"
  ],
  "contributes": {
    "languages": [
      {
        "id": "sclang",
        "aliases": [
          "SuperCollider",
          "sclang"
        ],
        "extensions": [
          ".sc",
          ".scs",
          ".scd",
          ".scnb"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sclang",
        "scopeName": "source.sclang",
        "path": "./syntaxes/sclang.tmLanguage.json"
      }
    ],
    "notebooks": [
      {
        "type": "supercollider-notebook",
        "displayName": "SuperCollider Notebook",
        "selector": [
          {
            "filenamePattern": "*.scnb"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "supercollider-notebook.freeAll",
        "icon": "$(mute)",
        "title": "Free Server"
      },
      {
        "command": "supercollider-notebook.bootServer",
        "icon": "$(run)",
        "title": "Boot Server"
      },
      {
        "command": "supercollider-notebook.rebootServer",
        "icon": "$(run-all)",
        "title": "Reboot Server"
      },
      {
        "command": "supercollider-notebook.executeSnippet",
        "title": "SuperCollider: Run selection or current scope"
      }
    ],
    "keybindings": [
      {
        "command": "supercollider-notebook.freeAll",
        "key": "ctrl+.",
        "mac": "cmd+.",
        "when": "notebookEditorFocused && resourceExtname == .scnb"
      },
      {
        "command": "supercollider-notebook.bootServer",
        "key": "ctrl+B",
        "mac": "cmd+B",
        "when": "notebookEditorFocused && resourceExtname == .scnb"
      },
      {
        "command": "supercollider-notebook.rebootServer",
        "key": "ctrl+shift+.",
        "mac": "cmd+shift+.",
        "when": "notebookEditorFocused && resourceExtname == .scnb"
      },
      {
        "command": "supercollider-notebook.executeSnippet",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "notebookEditorFocused && resourceExtname == .scnb"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "SuperCollider Notebook",
      "properties": {
        "supercollider.sclang.Path": {
          "type": "string",
          "default": "/Applications/SuperCollider.app/Contents/MacOS/sclang",
          "description": "Path to the SuperCollider sclang executable. Set this if sclang is not on your PATH."
        }
      }
    },
    "menus": {
      "notebook/toolbar": [
        {
          "command": "supercollider-notebook.freeAll",
          "group": "navigation@1",
          "when": "notebookType == supercollider-notebook"
        },
        {
          "command": "supercollider-notebook.bootServer",
          "group": "navigation@2",
          "when": "notebookType == supercollider-notebook"
        },
        {
          "command": "supercollider-notebook.rebootServer",
          "group": "navigation@3",
          "when": "notebookType == supercollider-notebook"
        }
      ]
    }
  },
  "dependencies": {
    "supercolliderjs": "^1.0.1"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.2",
    "mock-require": "^3.0.3",
    "parcel": "^2.16.4"
  }
}
