{
  "name": "supercollider-notebook",
  "displayName": "SuperCollider Notebook",
  "description": "Minimal VS Code notebook prototype for SuperCollider (execute cells via sclang).",
  "version": "0.0.1",
  "publisher": "gtwiggs",
  "engines": {
    "vscode": "^1.75.0"
  },
  "main": "./extension.js",
  "scripts": {
    "test": "node test-getScopeRange.js"
  },
  "activationEvents": [
    "onNotebook:supercollider-notebook"
  ],
  "categories": ["Other"],
  "contributes": {
    "languages": [
      {
        "id": "sclang",
        "aliases": ["SuperCollider", "sclang"],
        "extensions": [".sc", ".scs", ".scd", ".scnb"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sclang",
        "scopeName": "source.sclang",
        "path": "./syntaxes/sclang.tmLanguage.json"
      }
    ],
    "notebooks": [
      {
        "type": "supercollider-notebook",
        "displayName": "SuperCollider Notebook",
        "selector": [
          { "filenamePattern": "*.scnb" }
        ]
      }
    ],
    "commands": [
      {
        "command": "supercollider-notebook.freeAll",
        "title": "SuperCollider: s.freeAll"
      },
      {
        "command": "supercollider-notebook.bootServer",
        "title": "SuperCollider: boot server"
      },
      {
        "command": "supercollider-notebook.rebootServer",
        "title": "SuperCollider: reboot server"
      },
      {
        "command": "supercollider-notebook.runSelectionOrScope",
        "title": "SuperCollider: Run selection or current scope"
      }
    ],
    "keybindings": [
      {
        "command": "supercollider-notebook.freeAll",
        "key": "ctrl+.",
        "mac": "cmd+.",
        "when": "notebookEditorFocused && resourceExtname == .scnb"
      },
      {
        "command": "supercollider-notebook.bootServer",
        "key": "ctrl+B",
        "mac": "cmd+B",
        "when": "notebookEditorFocused && resourceExtname == .scnb"
      },
      {
        "command": "supercollider-notebook.rebootServer",
        "key": "ctrl+shift+.",
        "mac": "cmd+shift+.",
        "when": "notebookEditorFocused && resourceExtname == .scnb"
      },
      {
        "command": "supercollider-notebook.runSelectionOrScope",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "notebookEditorFocused && resourceExtname == .scnb"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "SuperCollider Notebook",
      "properties": {
        "supercollider.sclang.Path": {
          "type": "string",
          "default": "/Applications/SuperCollider.app/Contents/MacOS/sclang",
          "description": "Path to the SuperCollider sclang executable. Set this if sclang is not on your PATH."
        }
      }
    }
  }
}
